{
    "target_layout": "admin_ecommerce_order_detail",
    "data_sources": [
        {
            "id": "kginicis_status",
            "type": "api",
            "endpoint": "/api/plugins/sirsoft-pay-kginicis/admin/orders/{{route.orderNumber}}/transaction-status",
            "method": "GET",
            "auto_fetch": true,
            "auth_required": true
        }
    ],
    "injections": [
        {
            "target_id": "sticky_header_container",
            "position": "append_child",
            "components": [
                {
                    "type": "basic",
                    "name": "Div",
                    "if": "{{kginicis_status.data?._is_test_mode === true}}",
                    "props": { "className": "mx-6 mb-3 px-3 py-2 bg-orange-50 dark:bg-orange-900/20 border border-orange-200 dark:border-orange-700 rounded-lg flex items-center gap-2" },
                    "children": [
                        {
                            "type": "basic",
                            "name": "Icon",
                            "props": { "name": "flask-conical", "className": "w-4 h-4 text-orange-600 dark:text-orange-400 flex-shrink-0" }
                        },
                        {
                            "type": "basic",
                            "name": "Span",
                            "props": { "className": "text-sm font-semibold text-orange-800 dark:text-orange-300" },
                            "text": "$t:sirsoft-pay-kginicis.admin.test_mode_badge"
                        },
                        {
                            "type": "basic",
                            "name": "Span",
                            "props": { "className": "text-sm text-orange-700 dark:text-orange-400" },
                            "text": "$t:sirsoft-pay-kginicis.admin.test_mode_order_notice"
                        }
                    ]
                }
            ]
        },
        {
            "target_id": "tab_content_area",
            "position": "append_child",
            "components": [
                {
                    "id": "kginicis_verify_panel",
                    "type": "basic",
                    "name": "Div",
                    "if": "{{(order.data?.payments?.filter(p => p.transaction_id && p.pg_provider === 'kginicis') ?? []).length > 0}}",
                    "props": {
                        "className": "card"
                    },
                    "children": [
                        {
                            "id": "kginicis_verify_header",
                            "type": "basic",
                            "name": "Div",
                            "props": { "className": "flex items-center gap-2 mb-4" },
                            "children": [
                                {
                                    "type": "basic",
                                    "name": "Div",
                                    "props": { "className": "w-1.5 h-4 bg-blue-500 rounded-full flex-shrink-0" }
                                },
                                {
                                    "type": "basic",
                                    "name": "H3",
                                    "props": { "className": "text-sm font-semibold text-gray-800 dark:text-gray-200" },
                                    "text": "$t:sirsoft-pay-kginicis.admin.order_verify_title"
                                },
                                {
                                    "type": "basic",
                                    "name": "Span",
                                    "props": { "className": "text-xs text-gray-400 dark:text-gray-500 hidden sm:inline" },
                                    "text": "$t:sirsoft-pay-kginicis.admin.order_verify_description"
                                }
                            ]
                        },
                        {
                            "id": "kginicis_payments_list",
                            "type": "basic",
                            "name": "Div",
                            "props": { "className": "space-y-3" },
                            "iteration": {
                                "source": "{{order.data?.payments?.filter(p => p.transaction_id && p.pg_provider === 'kginicis') ?? []}}",
                                "item_var": "payment",
                                "index_var": "pIdx"
                            },
                            "children": [
                                {
                                    "type": "basic",
                                    "name": "Div",
                                    "props": { "className": "rounded-lg border border-gray-100 dark:border-gray-700 p-3 bg-gray-50 dark:bg-gray-800/50" },
                                    "children": [
                                        {
                                            "type": "basic",
                                            "name": "Div",
                                            "props": { "className": "flex flex-wrap items-center gap-3" },
                                            "children": [
                                                {
                                                    "type": "basic",
                                                    "name": "Div",
                                                    "props": { "className": "flex-1 min-w-0" },
                                                    "children": [
                                                        {
                                                            "type": "basic",
                                                            "name": "Span",
                                                            "props": { "className": "text-xs text-gray-500 dark:text-gray-400 block mb-0.5" },
                                                            "text": "TID"
                                                        },
                                                        {
                                                            "type": "basic",
                                                            "name": "Span",
                                                            "props": { "className": "font-mono text-xs text-gray-900 dark:text-gray-100 break-all block" },
                                                            "text": "{{payment.transaction_id}}"
                                                        }
                                                    ]
                                                },
                                                {
                                                    "type": "basic",
                                                    "name": "Button",
                                                    "props": {
                                                        "disabled": "{{_local._kginicisQuerying && _local._kginicisActiveTid === payment.transaction_id}}",
                                                        "className": "flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium bg-blue-600 hover:bg-blue-700 text-white rounded-md transition-colors disabled:opacity-50 disabled:cursor-not-allowed whitespace-nowrap flex-shrink-0"
                                                    },
                                                    "actions": [
                                                        {
                                                            "type": "click",
                                                            "handler": "sequence",
                                                            "actions": [
                                                                {
                                                                    "handler": "setState",
                                                                    "params": {
                                                                        "target": "local",
                                                                        "_kginicisQuerying": true,
                                                                        "_kginicisActiveTid": "{{payment.transaction_id}}",
                                                                        "_kginicisResult": null,
                                                                        "_kginicisError": null
                                                                    }
                                                                },
                                                                {
                                                                    "handler": "apiCall",
                                                                    "auth_required": true,
                                                                    "target": "/api/plugins/sirsoft-pay-kginicis/admin/transaction/query",
                                                                    "params": {
                                                                        "method": "POST",
                                                                        "body": {
                                                                            "tid": "{{_local._kginicisActiveTid}}"
                                                                        }
                                                                    },
                                                                    "onSuccess": [
                                                                        {
                                                                            "handler": "setState",
                                                                            "params": {
                                                                                "target": "local",
                                                                                "_kginicisQuerying": false,
                                                                                "_kginicisResult": "{{response.data}}"
                                                                            }
                                                                        }
                                                                    ],
                                                                    "onError": [
                                                                        {
                                                                            "handler": "setState",
                                                                            "params": {
                                                                                "target": "local",
                                                                                "_kginicisQuerying": false,
                                                                                "_kginicisError": "$t:sirsoft-pay-kginicis.admin.order_verify_error"
                                                                            }
                                                                        }
                                                                    ]
                                                                }
                                                            ]
                                                        }
                                                    ],
                                                    "children": [
                                                        {
                                                            "type": "basic",
                                                            "name": "Icon",
                                                            "if": "{{_local._kginicisQuerying && _local._kginicisActiveTid === payment.transaction_id}}",
                                                            "props": { "name": "spinner", "className": "w-3 h-3 animate-spin" }
                                                        },
                                                        {
                                                            "type": "basic",
                                                            "name": "Span",
                                                            "text": "$t:sirsoft-pay-kginicis.admin.order_verify_button"
                                                        }
                                                    ]
                                                }
                                            ]
                                        },
                                        {
                                            "type": "basic",
                                            "name": "Div",
                                            "if": "{{_local._kginicisActiveTid === payment.transaction_id && _local._kginicisError}}",
                                            "props": { "className": "mt-2 text-xs text-red-600 dark:text-red-400 bg-red-50 dark:bg-red-900/20 rounded px-2 py-1.5" },
                                            "text": "{{_local._kginicisError}}"
                                        },
                                        {
                                            "id": "kginicis_verify_result",
                                            "type": "basic",
                                            "name": "Div",
                                            "if": "{{(_local._kginicisActiveTid === payment.transaction_id && _local._kginicisResult) || kginicis_status.data}}",
                                            "props": { "className": "mt-3 pt-3 border-t border-gray-200 dark:border-gray-700" },
                                            "children": [
                                                {
                                                    "type": "basic",
                                                    "name": "Div",
                                                    "props": { "className": "flex items-center flex-wrap gap-2 mb-3" },
                                                    "children": [
                                                        {
                                                            "type": "basic",
                                                            "name": "Span",
                                                            "if": "{{(_local._kginicisResult ?? kginicis_status.data).resultCode === '00' || (_local._kginicisResult ?? kginicis_status.data).resultCode === 'SUCCESS'}}",
                                                            "props": { "className": "inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-300" },
                                                            "text": "$t:sirsoft-pay-kginicis.admin.pay_status_approved"
                                                        },
                                                        {
                                                            "type": "basic",
                                                            "name": "Span",
                                                            "if": "{{(_local._kginicisResult ?? kginicis_status.data).resultCode !== '00' && (_local._kginicisResult ?? kginicis_status.data).resultCode !== 'SUCCESS'}}",
                                                            "props": { "className": "inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold bg-amber-100 text-amber-800 dark:bg-amber-900/30 dark:text-amber-300" },
                                                            "text": "$t:sirsoft-pay-kginicis.admin.pay_status_unknown"
                                                        },
                                                        {
                                                            "type": "basic",
                                                            "name": "Span",
                                                            "if": "{{(_local._kginicisResult ?? kginicis_status.data)?._local_is_escrow === true}}",
                                                            "props": { "className": "inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-semibold bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-300" },
                                                            "children": [
                                                                {
                                                                    "type": "basic",
                                                                    "name": "Icon",
                                                                    "props": { "name": "shield-check", "className": "w-3 h-3" }
                                                                },
                                                                {
                                                                    "type": "basic",
                                                                    "name": "Span",
                                                                    "text": "$t:sirsoft-pay-kginicis.admin.escrow_badge"
                                                                }
                                                            ]
                                                        },
                                                        {
                                                            "type": "basic",
                                                            "name": "Span",
                                                            "if": "{{(_local._kginicisResult ?? kginicis_status.data)?._is_test_mode === true}}",
                                                            "props": { "className": "inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold bg-orange-100 text-orange-800 dark:bg-orange-900/30 dark:text-orange-300" },
                                                            "text": "$t:sirsoft-pay-kginicis.admin.test_mode_badge"
                                                        }
                                                    ]
                                                },
                                                {
                                                    "type": "basic",
                                                    "name": "Div",
                                                    "props": { "className": "grid grid-cols-2 gap-x-4 gap-y-1.5 text-xs" },
                                                    "children": [
                                                        {
                                                            "type": "basic",
                                                            "name": "Span",
                                                            "props": { "className": "text-gray-500 dark:text-gray-400" },
                                                            "text": "$t:sirsoft-pay-kginicis.admin.result_auth_code"
                                                        },
                                                        {
                                                            "type": "basic",
                                                            "name": "Span",
                                                            "props": { "className": "text-gray-900 dark:text-gray-100 font-mono" },
                                                            "text": "{{(_local._kginicisResult ?? kginicis_status.data)._auth_code ?? '-'}}"
                                                        },
                                                        {
                                                            "type": "basic",
                                                            "name": "Span",
                                                            "props": { "className": "text-gray-500 dark:text-gray-400" },
                                                            "text": "$t:sirsoft-pay-kginicis.admin.result_auth_date"
                                                        },
                                                        {
                                                            "type": "basic",
                                                            "name": "Span",
                                                            "props": { "className": "text-gray-900 dark:text-gray-100 font-mono" },
                                                            "text": "{{(_local._kginicisResult ?? kginicis_status.data)._auth_date ?? '-'}}"
                                                        },
                                                        {
                                                            "type": "basic",
                                                            "name": "Span",
                                                            "props": { "className": "text-gray-500 dark:text-gray-400" },
                                                            "text": "$t:sirsoft-pay-kginicis.admin.result_pay_method"
                                                        },
                                                        {
                                                            "type": "basic",
                                                            "name": "Span",
                                                            "props": { "className": "text-gray-900 dark:text-gray-100" },
                                                            "text": "{{(_local._kginicisResult ?? kginicis_status.data)._pay_method ?? '-'}}"
                                                        },
                                                        {
                                                            "type": "basic",
                                                            "name": "Span",
                                                            "props": { "className": "text-gray-500 dark:text-gray-400" },
                                                            "text": "$t:sirsoft-pay-kginicis.admin.result_result_code"
                                                        },
                                                        {
                                                            "type": "basic",
                                                            "name": "Span",
                                                            "props": { "className": "font-mono text-gray-900 dark:text-gray-100" },
                                                            "text": "{{((_local._kginicisResult ?? kginicis_status.data).resultCode ?? '') + ' ' + ((_local._kginicisResult ?? kginicis_status.data).resultMsg ?? '')}}"
                                                        }
                                                    ]
                                                }
                                            ]
                                        }
                                    ]
                                }
                            ]
                        }
                    ]
                },
                {
                    "id": "kginicis_cash_receipt_panel",
                    "type": "basic",
                    "name": "Div",
                    "if": "{{(order.data?.payments?.filter(p => p.transaction_id && p.pg_provider === 'kginicis') ?? []).length > 0}}",
                    "props": { "className": "card mt-4" },
                    "children": [
                        {
                            "type": "basic",
                            "name": "Div",
                            "props": { "className": "flex items-center gap-2 mb-4" },
                            "children": [
                                {
                                    "type": "basic",
                                    "name": "Div",
                                    "props": { "className": "w-1.5 h-4 bg-green-500 rounded-full flex-shrink-0" }
                                },
                                {
                                    "type": "basic",
                                    "name": "H3",
                                    "props": { "className": "text-sm font-semibold text-gray-800 dark:text-gray-200" },
                                    "text": "$t:sirsoft-pay-kginicis.admin.cash_receipt_title"
                                },
                                {
                                    "type": "basic",
                                    "name": "Span",
                                    "props": { "className": "text-xs text-gray-400 dark:text-gray-500 hidden sm:inline" },
                                    "text": "$t:sirsoft-pay-kginicis.admin.cash_receipt_description"
                                }
                            ]
                        },
                        {
                            "type": "basic",
                            "name": "Div",
                            "props": { "className": "space-y-3" },
                            "iteration": {
                                "source": "{{order.data?.payments?.filter(p => p.transaction_id && p.pg_provider === 'kginicis') ?? []}}",
                                "item_var": "payment",
                                "index_var": "crIdx"
                            },
                            "children": [
                                {
                                    "type": "basic",
                                    "name": "Div",
                                    "props": { "className": "rounded-lg border border-gray-100 dark:border-gray-700 p-3 bg-gray-50 dark:bg-gray-800/50" },
                                    "children": [
                                        {
                                            "type": "basic",
                                            "name": "Div",
                                            "props": { "className": "flex flex-wrap items-center gap-3 mb-3" },
                                            "children": [
                                                {
                                                    "type": "basic",
                                                    "name": "Span",
                                                    "props": { "className": "font-mono text-xs text-gray-500 dark:text-gray-400 break-all" },
                                                    "text": "{{payment.transaction_id}}"
                                                },
                                                {
                                                    "type": "basic",
                                                    "name": "Span",
                                                    "if": "{{payment.is_cash_receipt_issued}}",
                                                    "props": { "className": "inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-semibold bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-300" },
                                                    "children": [
                                                        { "type": "basic", "name": "Icon", "props": { "name": "check-circle", "className": "w-3 h-3" } },
                                                        { "type": "basic", "name": "Span", "text": "$t:sirsoft-pay-kginicis.admin.cash_receipt_already_issued" }
                                                    ]
                                                }
                                            ]
                                        },
                                        {
                                            "type": "basic",
                                            "name": "Div",
                                            "if": "{{payment.is_cash_receipt_issued}}",
                                            "props": { "className": "grid grid-cols-2 gap-x-4 gap-y-1 text-xs" },
                                            "children": [
                                                {
                                                    "type": "basic",
                                                    "name": "Span",
                                                    "props": { "className": "text-gray-500 dark:text-gray-400" },
                                                    "text": "$t:sirsoft-pay-kginicis.admin.cash_receipt_issued_at"
                                                },
                                                {
                                                    "type": "basic",
                                                    "name": "Span",
                                                    "props": { "className": "text-gray-900 dark:text-gray-100 font-mono" },
                                                    "text": "{{payment.cash_receipt_issued_at ?? '-'}}"
                                                },
                                                {
                                                    "type": "basic",
                                                    "name": "Span",
                                                    "props": { "className": "text-gray-500 dark:text-gray-400" },
                                                    "text": "$t:sirsoft-pay-kginicis.admin.cash_receipt_type_label"
                                                },
                                                {
                                                    "type": "basic",
                                                    "name": "Span",
                                                    "props": { "className": "text-gray-900 dark:text-gray-100" },
                                                    "text": "{{payment.cash_receipt_type === 'income_deduction' ? '$t:sirsoft-pay-kginicis.admin.cash_receipt_type_income' : '$t:sirsoft-pay-kginicis.admin.cash_receipt_type_expenditure'}}"
                                                }
                                            ]
                                        },
                                        {
                                            "type": "basic",
                                            "name": "Div",
                                            "if": "{{!payment.is_cash_receipt_issued}}",
                                            "props": { "className": "space-y-2" },
                                            "children": [
                                                {
                                                    "type": "basic",
                                                    "name": "Div",
                                                    "props": { "className": "flex items-center gap-2" },
                                                    "children": [
                                                        {
                                                            "type": "basic",
                                                            "name": "Label",
                                                            "props": { "className": "text-xs text-gray-500 dark:text-gray-400 w-16 flex-shrink-0" },
                                                            "text": "$t:sirsoft-pay-kginicis.admin.cash_receipt_type_label"
                                                        },
                                                        {
                                                            "type": "basic",
                                                            "name": "Select",
                                                            "props": {
                                                                "name": "_cr_issue_type",
                                                                "data-idx": "{{crIdx}}",
                                                                "className": "flex-1 text-xs px-2 py-1.5 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100"
                                                            },
                                                            "actions": [
                                                                {
                                                                    "type": "change",
                                                                    "handler": "setState",
                                                                    "params": {
                                                                        "target": "local",
                                                                        "_cr_issue_type_{{crIdx}}": "{{$event.target.value}}"
                                                                    }
                                                                }
                                                            ],
                                                            "children": [
                                                                {
                                                                    "type": "basic",
                                                                    "name": "Option",
                                                                    "props": { "value": "0" },
                                                                    "text": "$t:sirsoft-pay-kginicis.admin.cash_receipt_type_income"
                                                                },
                                                                {
                                                                    "type": "basic",
                                                                    "name": "Option",
                                                                    "props": { "value": "1" },
                                                                    "text": "$t:sirsoft-pay-kginicis.admin.cash_receipt_type_expenditure"
                                                                }
                                                            ]
                                                        }
                                                    ]
                                                },
                                                {
                                                    "type": "basic",
                                                    "name": "Div",
                                                    "props": { "className": "flex items-center gap-2" },
                                                    "children": [
                                                        {
                                                            "type": "basic",
                                                            "name": "Label",
                                                            "props": { "className": "text-xs text-gray-500 dark:text-gray-400 w-16 flex-shrink-0" },
                                                            "text": "$t:sirsoft-pay-kginicis.admin.cash_receipt_number_label"
                                                        },
                                                        {
                                                            "type": "basic",
                                                            "name": "Input",
                                                            "props": {
                                                                "type": "text",
                                                                "placeholder": "$t:sirsoft-pay-kginicis.admin.cash_receipt_number_placeholder_income",
                                                                "className": "flex-1 text-xs px-2 py-1.5 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 font-mono"
                                                            },
                                                            "actions": [
                                                                {
                                                                    "type": "change",
                                                                    "handler": "setState",
                                                                    "params": {
                                                                        "target": "local",
                                                                        "_cr_issue_number_{{crIdx}}": "{{$event.target.value}}"
                                                                    }
                                                                }
                                                            ]
                                                        },
                                                        {
                                                            "type": "basic",
                                                            "name": "Button",
                                                            "props": {
                                                                "disabled": "{{_local._cr_issuing_{{crIdx}}}}",
                                                                "className": "flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium bg-green-600 hover:bg-green-700 text-white rounded-md transition-colors disabled:opacity-50 disabled:cursor-not-allowed whitespace-nowrap flex-shrink-0"
                                                            },
                                                            "actions": [
                                                                {
                                                                    "type": "click",
                                                                    "handler": "sequence",
                                                                    "actions": [
                                                                        {
                                                                            "handler": "setState",
                                                                            "params": {
                                                                                "target": "local",
                                                                                "_cr_issuing_{{crIdx}}": true,
                                                                                "_cr_error_{{crIdx}}": null
                                                                            }
                                                                        },
                                                                        {
                                                                            "handler": "apiCall",
                                                                            "auth_required": true,
                                                                            "target": "/api/plugins/sirsoft-pay-kginicis/admin/orders/{{route.orderNumber}}/cash-receipt",
                                                                            "params": {
                                                                                "method": "POST",
                                                                                "body": {
                                                                                    "issue_type": "{{_local._cr_issue_type_{{crIdx}} ?? '0'}}",
                                                                                    "issue_number": "{{_local._cr_issue_number_{{crIdx}} ?? ''}}"
                                                                                }
                                                                            },
                                                                            "onSuccess": [
                                                                                {
                                                                                    "handler": "setState",
                                                                                    "params": {
                                                                                        "target": "local",
                                                                                        "_cr_issuing_{{crIdx}}": false
                                                                                    }
                                                                                },
                                                                                {
                                                                                    "handler": "toast",
                                                                                    "params": { "type": "success", "message": "$t:sirsoft-pay-kginicis.admin.cash_receipt_success" }
                                                                                },
                                                                                {
                                                                                    "handler": "refetchDataSource",
                                                                                    "params": { "dataSourceId": "order" }
                                                                                }
                                                                            ],
                                                                            "onError": [
                                                                                {
                                                                                    "handler": "setState",
                                                                                    "params": {
                                                                                        "target": "local",
                                                                                        "_cr_issuing_{{crIdx}}": false,
                                                                                        "_cr_error_{{crIdx}}": "$t:sirsoft-pay-kginicis.admin.cash_receipt_error"
                                                                                    }
                                                                                }
                                                                            ]
                                                                        }
                                                                    ]
                                                                }
                                                            ],
                                                            "children": [
                                                                {
                                                                    "type": "basic",
                                                                    "name": "Icon",
                                                                    "if": "{{_local._cr_issuing_{{crIdx}}}}",
                                                                    "props": { "name": "spinner", "className": "w-3 h-3 animate-spin" }
                                                                },
                                                                {
                                                                    "type": "basic",
                                                                    "name": "Span",
                                                                    "if": "{{_local._cr_issuing_{{crIdx}}}}",
                                                                    "text": "$t:sirsoft-pay-kginicis.admin.cash_receipt_issuing"
                                                                },
                                                                {
                                                                    "type": "basic",
                                                                    "name": "Span",
                                                                    "if": "{{!_local._cr_issuing_{{crIdx}}}}",
                                                                    "text": "$t:sirsoft-pay-kginicis.admin.cash_receipt_issue_button"
                                                                }
                                                            ]
                                                        }
                                                    ]
                                                },
                                                {
                                                    "type": "basic",
                                                    "name": "Div",
                                                    "if": "{{_local._cr_error_{{crIdx}}}}",
                                                    "props": { "className": "text-xs text-red-600 dark:text-red-400 bg-red-50 dark:bg-red-900/20 rounded px-2 py-1.5" },
                                                    "text": "{{_local._cr_error_{{crIdx}}}}"
                                                }
                                            ]
                                        }
                                    ]
                                }
                            ]
                        }
                    ]
                }
            ]
        }
    ]
}
